# Runtime mode
COMPOSE_PROJECT_NAME=egdev-dashboard

# Images validated during M1 runtime research. Pin base images to version tags
# before production-like use if repeatability matters more than following latest.
OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_RUNTIME_IMAGE=egdev-dashboard-openclaw:local
ENGRAM_IMAGE=ghcr.io/gentleman-programming/engram:latest

# OpenClaw Gateway
# Replace before real use. The example value is only for local smoke testing.
OPENCLAW_GATEWAY_TOKEN=change-me-local-openclaw-token
OPENCLAW_GATEWAY_PORT=18789
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_PREFIX=egdev

# Engram Cloud runtime
# Replace every change-me value before storing real memory.
POSTGRES_USER=engram
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_DB=engram_cloud
ENGRAM_JWT_SECRET=change-me-local-jwt-secret-32-bytes-minimum
ENGRAM_CLOUD_TOKEN=change-me-local-engram-token
ENGRAM_CLOUD_ADMIN=change-me-local-engram-admin-token
ENGRAM_CLOUD_ALLOWED_PROJECTS=egdev-dashboard
ENGRAM_CLOUD_URL=http://engram:18080
ENGRAM_PORT=18080
ENGRAM_NAMESPACE_PREFIX=egdev-dashboard

# Buffer integration (future milestones)
BUFFER_ACCESS_TOKEN=
BUFFER_ACCOUNT_ID=
