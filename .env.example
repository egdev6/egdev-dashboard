# Runtime mode
COMPOSE_PROJECT_NAME=egdev-dashboard

# Replace these with confirmed image references before running Docker Compose.
OPENCLAW_IMAGE=
ENGRAM_IMAGE=

# OpenClaw runtime
OPENCLAW_AGENT_NAME=egdev-dashboard
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_PREFIX=egdev

# Engram runtime
ENGRAM_PROJECT=egdev-dashboard
ENGRAM_NAMESPACE_PREFIX=egdev-dashboard
ENGRAM_API_URL=
ENGRAM_API_TOKEN=

# Buffer integration (future milestones)
BUFFER_ACCESS_TOKEN=
BUFFER_ACCOUNT_ID=

# Optional loopback-only local ports
OPENCLAW_PORT=3000
ENGRAM_PORT=8080
